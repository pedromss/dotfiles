#!/usr/bin/env bash 

if [ -z "$DOTFILES_NVM_VERSION" ] ; then export DOTFILES_NVM_VERSION='v0.35.2' ; fi
if [ -z "$DOTFILES_NODE_VERSION" ] ; then export DOTFILES_NODE_VERSION='12.16.1' ; fi
export DOTFILES_NVM_DIR="$DOTFILES_BIN/nvm"
export NVM_DIR="$DOTFILES_NVM_DIR"
export PATH="$DOTFILES_NVM_DIR:$PATH"

