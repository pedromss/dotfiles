#!/usr/bin/env bash
# Exa https://github.com/ogham/exa
alias lr="exa --group-directories-first --header --long --recurse --group --modified --created --git --all --all"
alias lrt="exa --group-directories-first --header --tree --long --recurse --group --modified --created --git"
alias l="exa --group-directories-first --header --long --group --modified --created --git --all --all"
alias ls="exa --group-directories-first -1"
