#!/usr/bin/env bash

session_name='rpi-cluster'

tmux -2 new-session -d -s "$session_name"
tmux rename-window -t "${session_name}:0" "$session_name"
tmux split-window -h
tmux select-pane -t 0
tmux split-window -v
tmux select-pane -t 1
tmux split-window -v
tmux select-pane -t 0

tmux select-window -t "${session_name}:1"
