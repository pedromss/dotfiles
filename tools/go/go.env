#!/usr/bin/env bash

[ -n "$DOTFILES_GOLANG_VERSION" ] || export DOTFILES_GOLANG_VERSION='1.12.6'
export DOTFILES_GOLANG_ROOT_PARENT="$DOTFILES_BIN"
export DOTFILES_GOLANG_ROOT="$DOTFILES_GOLANG_ROOT_PARENT/go"
export DOTFILES_GOLANG_GOPATH="$DOTFILES_USER_HOME/go"
export PATH="$DOTFILES_BIN/go/bin:$DOTFILES_GOLANG_GOPATH/bin:/usr/local/go/bin:$PATH"
export GOPATH="$DOTFILES_GOLANG_GOPATH"
export GO111MODULE='off'

