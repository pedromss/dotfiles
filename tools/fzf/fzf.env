#!/usr/bin/env zsh

export DOTFILES_FZF_VERSION='0.20.0'
export FZF_CTRL_T_OPTS="--preview '(highlight -O ansi -l {} 2> /dev/null || bat {} || tree -C {}) 2> /dev/null | head -200'"
export FZF_CTRL_R_OPTS="--preview 'echo {}' --preview-window down:3:hidden:wrap --bind '?:toggle-preview'"
export FZF_DEFAULT_OPTS='--height 10% --layout=reverse --border'

# junegunn/fzf.vim has limitation regarding configurability so this needs to be
# at home
export DOTFILES_FZF_DIR="$DOTFILES_BIN/fzf"
export PATH="$DOTFILES_FZF_DIR/bin:$PATH"
