#!/usr/bin/env bash 

export DISABLE_AUTO_UPDATE="0"
export DOTFILES_ZSH_PLUGINS_FOLDER="$DOTFILES_BIN/zsh-plugins"
export DOTFILES_ZPLUG_HOME="$DOTFILES_BIN/zplug"
export ZPLUG_HOME="$DOTFILES_ZPLUG_HOME"
export DOTFILES_ZPLUG_PROTOCOL='https'
export ZPLUG_PROTOCOL="$DOTFILES_ZPLUG_PROTOCOL"
export DOTFILES_ZPLUG_CONFIG_FILE="$DOTFILES_FULL_PATH/tools/zsh/zplug"

mkdir -p "$DOTFILES_ZSH_PLUGINS_FOLDER"
