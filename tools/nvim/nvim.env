#!/usr/bin/env bash 

export DOTFILES_NVIM_INSTALLATION="$DOTFILES_BIN/neovim"
export DOTFILES_NVIM_CONFIG_FOLDER="$DOTFILES_XDG_CONFIG_HOME/nvim"
export DOTFILES_NVIM_DATA_FOLDER="$DOTFILES_XDG_DATA_HOME/nvim"

export PATH="$DOTFILES_NVIM_INSTALLATION/bin:$PATH"

mkdir -p "$DOTFILES_NVIM_CONFIG_FOLDER"
mkdir -p "$DOTFILES_NVIM_DATA_FOLDER"
