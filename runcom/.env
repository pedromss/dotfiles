export JAVA_HOME=$(/usr/libexec/java_home)
export SDKMAN_DIR="$HOME/.sdkman"
export ECLIPSE_HOME="/Applications/Eclipse Java.app/Contents/Eclipse"
export PATH=$PATH:$HOME/go/bin:/usr/local/go/bin:~/.sdkman/candidates/gradle/current/bin/:~/.sdkman/bin/:$ECLIPSE_HOME
export PATH=$PATH:$HOME/.vim/plugged/git-slides/bin
export GOPATH=$HOME/go
export XDG_CONFIG_HOME=~/.config
export XDG_DATA_HOME=~/.local/share

# NVM
export NVM_DIR="$HOME/.nvm"

# Conscript
export CONSCRIPT_HOME="$HOME/.conscript"
export CONSCRIPT_OPTS="-XX:MaxPermSize=512M -Dfile.encoding=UTF-8"
export PATH=$CONSCRIPT_HOME/bin:$PATH

# ZSH
export DISABLE_AUTO_UPDATE="0"

