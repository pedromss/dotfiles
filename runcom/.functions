#! /usr/bin/env bash

time_zsh() {
  for i in $(seq 1 $1); do /usr/bin/time zsh -i -c exit; done
}

mk() {
  mkdir -p $1 && cd $_
}

open_conns() {
  netstat -nat | awk '{print $6}' | sort | uniq -c | sort -n
}

pfds() {
  ps -ef | grep $1 | awk -F " " '{print $2;exit}' | xargs -L 1 bash -c 'ls -l "/proc/$0/fd"' | wc -l
}

gaacmp() {
  git add -A && git commit -m "$1" && git push
}

gaucmp() {
  git add -u && git commit -m "$1" && git push
}

command_exists() {
  type $1 1>/dev/null 2>/dev/null
}

cag() {
  if command_exists ag
  then
    ag $1 --numbers --pager less --stats --nopager "${@:2}"
  else
    echo 'Ag not installed, visit: https://github.com/ggreer/the_silver_searcher'
  fi
}


make_alias() {
  alias_path=$HOME/.dotfiles/runcom/.aliases
  echo "alias $1='$2'" >> $alias_path
  source $alias_path
}

# DOCKER
function docker_rmi_dangling() {
  if command_exists docker ;
  then
    docker rmi $(docker images -f dangling=true -q) "$@"
  else
    echo "Docker doesn't seem to be installed"
  fi
}

function docker_build_run() {
  if command_exists docker ;
  then
    docker build -t $1 . && docker --rm run $1 "$@"
  fi
}
