#! /usr/bin/env bash

mk() {
  mkdir -p $1 && cd $_
}

gaacmp() {
  git add -A && git commit -m "$1" && git push
}

gaucmp() {
  git add -u && git commit -m "$1" && git push
}

command_exists() {
  type $1 1>/dev/null 2>/dev/null
}

make_alias() {
  alias_path=$HOME/.dotfiles/runcom/.aliases
  echo "alias $1='$2'" >> $alias_path 
  source $alias_path
}

# DOCKER
function docker_rmi_dangling() {
  if command_exists docker ;
  then
    docker rmi $(docker images -f dangling=true -q) "$@"
  else
    echo "Docker doesn't seem to be installed"
  fi
}
