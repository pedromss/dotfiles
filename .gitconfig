[user]
	name = Pedro Silva
[alias]
  st = status -s --show-stash --branch -uall
  stl = status --long --branch --show-stash -uall -vv
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %Cblue<%an>%Creset' --abbrev-commit --date=relative
  ch = checkout
  au = add -u
  aa = add -A
  cm = commit -m
  br = branch -vv
  brr = branch -r -vv
	unstage = reset HEAD --
  chall = checkout -- .
[core]
	autocrlf = input
  editor = /usr/bin/vim
	excludesfile = /Users/psi24/.gitignore_global
;[diff]
  ;external = /usr/local/bin/git_diff_wrapper
[grep]
	lineNumber = true
[merge]
	;tool = splice
  tool = vimdiff
  conflictStyle = diff3
[mergetool]
	prompt = false
[mergetool "splice"]
  cmd = "nvim -f $BASE $LOCAL $REMOTE $MERGED -c 'SpliceInit'"
  trustExitCode = true
